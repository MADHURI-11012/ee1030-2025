    // 3. Calculation for the specific sequence (Intersection of independent events)
    // Formula: P(v1) * P(v2) * P(v3)
    result = prob[v1] * prob[v2] * prob[v3];

    printf("Probability of sequence (%d, %d, %d): %.10f\n", v1, v2, v3, result);
    return 0;
