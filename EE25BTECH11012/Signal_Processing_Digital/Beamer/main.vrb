\begin{lstlisting}
int main() {
    double x;

    printf("Enter the value of x: ");
    if (scanf("%lf", &x) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    double result = calculate_coth(x);

    if (!isnan(result)) {
        printf("coth(%.4f) = %.6f\n", x, result);
    }

    return 0;
}
\end{lstlisting}
